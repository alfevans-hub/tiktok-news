# News
NEWSAPI_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# ElevenLabs (voiceover audio)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=   # Optional — defaults to "Rachel". Find IDs at elevenlabs.io/voice-lab

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=  # Full key including -----BEGIN/END----- lines
FIREBASE_CLIENT_EMAIL=
FIREBASE_STORAGE_BUCKET=  # Usually: your-project-id.appspot.com

# Vercel Cron auth — any random string (openssl rand -hex 32)
CRON_SECRET=
